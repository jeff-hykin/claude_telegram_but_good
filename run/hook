#!/usr/bin/env -S deno run -A
// Claude Code PreToolUse/PostToolUse hook — forwards events to cbg server

const HOME = Deno.env.get("HOME")
const SOCK = HOME + "/.claude/channels/telegram/ipc.sock"
const LOG = HOME + "/claud_telegram.log"

let logDirReady = false
function log(msg) {
    try {
        if (!logDirReady) { Deno.mkdirSync(LOG + "/..", { recursive: true }); logDirReady = true }
        Deno.writeTextFileSync(LOG, `[HOOK ${new Date().toISOString()}] ${msg}\n`, { append: true, create: true })
    } catch {}
}

const input = await new Response(Deno.stdin.readable).text()

let hook = "unknown", tool = "unknown", session = "unknown"
let inputPreview = "", outputPreview = "", isError = false

try {
    const data = JSON.parse(input)
    hook = data.hook_event_name ?? "unknown"
    tool = data.tool_name ?? "unknown"
    session = data.session_id ?? "unknown"
    inputPreview = JSON.stringify(data.tool_input ?? "").slice(0, 200)
    outputPreview = JSON.stringify(data.tool_response ?? "").slice(0, 200)
    isError = !!data.tool_response?.error
} catch (e) {
    log(`JSON parse failed: ${e instanceof Error ? e.message : String(e)}`)
}

log(`hook=${hook} tool=${tool} session=${session}`)

try {
    const conn = await Deno.connect({ transport: "unix", path: SOCK })
    const msg = JSON.stringify({
        type: "hook_event",
        sessionId: session,
        hook,
        tool_name: tool,
        input_preview: inputPreview,
        output_preview: outputPreview,
        is_error: isError,
    })
    await conn.write(new TextEncoder().encode(msg + "\n"))
    try { await conn.closeWrite() } catch { /* ignore */ }
    const buf = new Uint8Array(1)
    await Promise.race([
        conn.read(buf),
        new Promise(r => setTimeout(r, 500)),
    ])
    conn.close()
} catch (e) {
    log(`IPC send failed: ${e instanceof Error ? e.message : String(e)}`)
}
