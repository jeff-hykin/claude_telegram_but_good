#!/usr/bin/env bash
# run/tests — execute the full Deno unit-test suite and regenerate
# snapshot fixtures (e.g. the peek TUI renderer goldens).
#
# Resolves the repo root relative to this script so it works regardless
# of the caller's CWD. `deno test tests/` doesn't discover files in
# this layout (names don't end in _test.ts/.js), so we glob explicitly.
#
# After running, check `git status` / `git diff tests/fixtures/` — any
# change there is a snapshot diff that needs human review before commit.

set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo="$(cd "$here/.." && pwd)"
cd "$repo"

echo "==> deno unit tests"
deno test --allow-all tests/*.js "$@"

echo
echo "==> regenerating peek TUI fixtures"
deno run --allow-read --allow-write tests/fixtures/peek/generate.js
